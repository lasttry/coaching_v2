generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "client" // enable Prisma ORM without Rust
}

datasource db {
  provider = "postgresql"
}

// Enums
enum IdType {
  PASSPORT
  NATIONAL_ID
  OTHER
}

enum ObjectiveType {
  OFFENSIVE
  DEFENSIVE
  TEAM
  INDIVIDUAL
}

enum Role {
  ADMIN
  DIRECTOR
  COACH
  PLAYER
  PARENT
  TEAM_MANAGER
}

enum StaffRole {
  HEAD_COACH
  ASSISTANT_COACH
  DIRECTOR
  TEAM_MANAGER
  PHYSIOTHERAPIST
  STATISTICIAN
  OTHER
}

enum CoachGrade {
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  TRAINEE
}

enum PlatformRole {
  ADMIN
  USER
  VIEWER
}

enum Gender {
  MALE
  FEMALE
  COED
}

enum TeamType {
  A
  B
  C
}

enum Size {
  S
  M
  L
  XL
  XXL
}

enum AlertType {
  INFO
  ATTENTION
  IMPORTANT
  PRIORITY
}

enum AlertCategory {
  ATHLETE_BIRTHDAY
}

enum AlertRecipientStatus {
  UNREAD
  READ
  DELETED
}

enum AttendanceDefault {
  ALL
  NONE
}

enum PracticeItemType {
  FREETEXT
  DRILL
  PLAY
  BREAKDOWN
  MY_DRILL
}

// Models

model Athlete {
  id                  Int                      @id @default(autoincrement())
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  number              String?                  @db.VarChar(2)
  name                String                   @db.VarChar(50)
  birthdate           DateTime?
  fpbNumber           Int?
  idNumber            Int?
  idType              IdType?
  active              Boolean                  @default(true)
  shirtSize           Size?
  photo               String?                  @db.Text
  clubId              Int
  club                Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  athleteReports      AthleteReport[]
  reviewedReports     AthleteReport[]          @relation("ReviewedAthlete")
  gameAthletes        GameAthlete[]
  statistics          Statistic[]
  timeEntries         TimeEntry[]
  teams               TeamAthlete[]
  preferredNumbers    AthletePreferredNumber[]
  gameEquipments      GameEquipment[]
  practiceAttendances PracticeAthlete[]
}

model GameAthlete {
  gameId    Int
  athleteId Int
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  athlete   Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  number    String?
  period1   Boolean?
  period2   Boolean?
  period3   Boolean?
  period4   Boolean?

  @@id([gameId, athleteId])
}

model Game {
  id                   Int               @id @default(autoincrement())
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  number               Int?
  date                 DateTime
  away                 Boolean
  notes                String?           @db.VarChar(1000)
  clubId               Int
  club                 Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamId               Int?
  team                 Team?             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  competitionId        Int?
  competition          Competition?      @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  competitionSerieId   Int?
  competitionSerie     CompetitionSerie? @relation(fields: [competitionSerieId], references: [id])
  opponentId           Int
  opponent             Opponent          @relation(fields: [opponentId], references: [id])
  venueId              Int?
  venue                Venue?            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  gameAthletes         GameAthlete[]
  gameEquipments       GameEquipment[]
  objectives           Objective[]       @relation("Objectives")
  athleteReports       AthleteReport[]
  statistics           Statistic[]
  timeEntries          TimeEntry[]
  refereeMain          String?
  referee1             String?
  scorer               String?
  timer                String?
  shotClock            String?
  opponentResultsCount Int               @default(5)
  speech               String?           @db.Text
  completed            Boolean           @default(false)

  fpbGameId Int? @unique

  image1 String?
  image2 String?
  image3 String?
  image4 String?
}

model Opponent {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  shortName String   @db.VarChar(6)
  image     String?
  fpbClubId Int?
  fpbTeamId Int?
  games     Game[]
  venues    Venue[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                Int              @id @default(autoincrement())
  name              String?          @db.VarChar(100)
  email             String           @unique @db.VarChar(100)
  password          String
  image             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  clubs             AccountClub[]    @relation("AccountToClubs")
  defaultClubId     Int              @default(0)
  role              PlatformRole     @default(USER)
  resetToken        String?          @unique
  resetTokenExpiry  DateTime?
  staffProfiles     Staff[]
  alertRecipients   AlertRecipient[]
  drills            Drill[]          @relation("DrillAuthor")
  /// List of the last custom colours the user has applied in the drill
  /// editor. Stored as JSON `{ color: string, pinned: boolean }[]`.
  drillRecentColors Json?
}

model Statistic {
  id                Int     @id @default(autoincrement())
  gameId            Int
  athleteId         Int
  freeThrowScored   Int     @default(0)
  freeThrowMissed   Int     @default(0)
  fieldGoalScored   Int     @default(0)
  fieldGoalMissed   Int     @default(0)
  threePtsScored    Int     @default(0)
  threePtsMissed    Int     @default(0)
  assists           Int     @default(0)
  defensiveRebounds Int     @default(0)
  offensiveRebounds Int     @default(0)
  blocks            Int     @default(0)
  steals            Int     @default(0)
  turnovers         Int     @default(0)
  fouls             Int     @default(0)
  totalRebounds     Int     @default(0)
  athlete           Athlete @relation(fields: [athleteId], references: [id])
  game              Game    @relation(fields: [gameId], references: [id])

  @@unique([gameId, athleteId])
}

model TimeEntry {
  id          Int     @id @default(autoincrement())
  gameId      Int
  athleteId   Int
  period      Int
  entryMinute Int
  entrySecond Int
  exitMinute  Int?
  exitSecond  Int?
  athlete     Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  game        Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId, athleteId, period])
}

model AthleteReport {
  id                    Int      @id @default(autoincrement())
  gameId                Int
  athleteId             Int
  teamObservation       String?  @db.VarChar(2000)
  individualObservation String?  @db.VarChar(2000)
  timePlayedObservation String?  @db.VarChar(2000)
  createdAt             DateTime @default(now())
  reviewedAthleteId     Int?
  athlete               Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  game                  Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  reviewedAthlete       Athlete? @relation("ReviewedAthlete", fields: [reviewedAthleteId], references: [id], onDelete: Cascade)

  @@unique([gameId, athleteId])
  @@index([gameId, athleteId])
}

model Macrocycle {
  id         Int         @id @default(autoincrement())
  startDate  DateTime
  endDate    DateTime
  notes      String?     @db.VarChar(1000)
  number     Int?
  name       String?
  clubId     Int
  club       Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamId     Int?
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  mesocycles Mesocycle[]
}

model Mesocycle {
  id           Int          @id @default(autoincrement())
  startDate    DateTime
  endDate      DateTime
  notes        String?      @db.VarChar(1000)
  macrocycleId Int
  number       Int?
  name         String?
  macrocycle   Macrocycle   @relation(fields: [macrocycleId], references: [id])
  microcycles  Microcycle[]
}

model Microcycle {
  id           Int           @id @default(autoincrement())
  notes        String?       @db.VarChar(1000)
  mesocycleId  Int
  number       Int?
  name         String?
  endDate      DateTime
  startDate    DateTime
  mesocycle    Mesocycle     @relation(fields: [mesocycleId], references: [id])
  sessionGoals SessionGoal[]
}

model SessionGoal {
  id           Int        @id @default(autoincrement())
  duration     Int
  note         String?    @db.VarChar(1000)
  coach        String     @db.VarChar(255)
  microcycleId Int
  date         DateTime
  order        Int
  microcycle   Microcycle @relation(fields: [microcycleId], references: [id], onDelete: Cascade)
}

model Objective {
  id          Int           @id @default(autoincrement())
  title       String        @db.VarChar(255)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  gameId      Int
  type        ObjectiveType
  game        Game          @relation("Objectives", fields: [gameId], references: [id], onDelete: Cascade)
}

model Drill {
  id        Int      @id @default(autoincrement())
  name      String?
  title     String?  @db.VarChar(255)
  svg       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  clubId    Int?
  club      Club?    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  accountId Int?
  account   Account? @relation("DrillAuthor", fields: [accountId], references: [id], onDelete: SetNull)
  echelonId Int?
  echelon   Echelon? @relation(fields: [echelonId], references: [id], onDelete: SetNull)

  description String? @db.Text
  goals       String? @db.Text
  variations  String? @db.Text
  tips        String? @db.Text
  defaultText String? @db.Text

  ballsCount     Int     @default(0)
  basketsCount   Int     @default(0)
  conesCount     Int     @default(0)
  extraEquipment String? @db.VarChar(255)

  playersCount Int @default(0)
  coachesCount Int @default(0)

  typeFundamental Boolean @default(false)
  typeIndividual  Boolean @default(false)
  typeTeam        Boolean @default(false)

  posGuard   Boolean @default(false)
  posForward Boolean @default(false)
  posCenter  Boolean @default(false)

  graphics      DrillGraphic[]
  topics        DrillTopicLink[]
  practiceItems PracticeItem[]

  @@index([clubId])
}

model DrillGraphic {
  id        Int      @id @default(autoincrement())
  drillId   Int
  drill     Drill    @relation(fields: [drillId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  svg       String   @db.Text
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([drillId, order])
}

/// Drill topic / category. Every topic belongs to a club — the defaults
/// are auto-seeded the first time a club's topics are read, and club
/// admins are free to add/rename/delete additional ones.
///
/// `key` is a stable identifier only present on seeded defaults, so the
/// UI can localise their name (e.g. `drill.topicNames.transition`).
/// Admin-created topics have `key = null` and the raw `name` is shown
/// verbatim.
model DrillTopic {
  id     Int              @id @default(autoincrement())
  clubId Int
  club   Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  key    String?          @db.VarChar(80)
  name   String           @db.VarChar(120)
  order  Int              @default(0)
  drills DrillTopicLink[]

  @@unique([clubId, key])
  @@index([clubId, order])
}

model DrillTopicLink {
  drillId Int
  topicId Int
  drill   Drill      @relation(fields: [drillId], references: [id], onDelete: Cascade)
  topic   DrillTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([drillId, topicId])
  @@index([topicId])
}

model Echelon {
  id              Int              @id @default(autoincrement())
  minAge          Int
  maxAge          Int?
  name            String           @db.VarChar(50)
  description     String?          @db.VarChar(255)
  gender          Gender
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  teams           Team[]
  competitions    Competition[]
  equipmentColors EquipmentColor[]
  drills          Drill[]
}

model Club {
  id               Int                   @id @default(autoincrement())
  name             String                @unique @db.VarChar(50)
  shortName        String?               @db.VarChar(6)
  image            String?
  federationLogo   String?               @db.Text
  backgroundColor  String?               @db.VarChar(7)
  foregroundColor  String?               @db.VarChar(7)
  // Court theme used by the drill graphic editor. Background may be either
  // a hex colour or a pattern id (`wood`, `parquet`, `concrete`, `clay`),
  // hence VarChar(16) instead of (7). Other colour fields are hex only.
  courtBackground  String?               @db.VarChar(16)
  courtKeyColor    String?               @db.VarChar(7)
  courtCenterColor String?               @db.VarChar(7)
  courtLineColor   String?               @db.VarChar(7)
  courtMarginColor String?               @db.VarChar(7)
  courtShowLogo    Boolean               @default(true)
  /* Rotation (degrees, 0/90/180/270) applied to the centre-circle logo so
   * the crest can sit upright when viewed from either end of the court. */
  courtLogoRotation Int                  @default(90)
  fpbClubId        Int?
  accounts         AccountClub[]         @relation("ClubToAccounts")
  athletes         Athlete[]
  games            Game[]
  macrocycles      Macrocycle[]
  teams            Team[]
  venues           Venue[]
  equipmentColors  EquipmentColor[]
  staff            Staff[]
  alerts           Alert[]
  emailSettings    ClubEmailSettings?
  practices         Practice[]
  practiceSettings  ClubPracticeSettings?
  attendanceReasons ClubAttendanceReason[]
  drills           Drill[]
  drillTopics      DrillTopic[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// SMTP settings used by a club to send outgoing emails (alerts, notifications).
/// `passEncrypted` is encrypted with AES-256-GCM using EMAIL_ENCRYPTION_KEY from the
/// environment. It is never returned as-is by any API; only `hasPassword` is exposed.
model ClubEmailSettings {
  id            Int      @id @default(autoincrement())
  clubId        Int      @unique
  club          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  enabled       Boolean  @default(false)
  host          String?  @db.VarChar(255)
  port          Int?
  secure        Boolean  @default(true)
  user          String?  @db.VarChar(255)
  passEncrypted String?  @db.Text
  fromEmail     String?  @db.VarChar(255)
  fromName      String?  @db.VarChar(100)
  replyTo       String?  @db.VarChar(255)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Season {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(10) // e.g. "2025/2026"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)

  equipmentColors EquipmentColor[]
}

model Venue {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(50)
  address    String?   @db.VarChar(100)
  opponentId Int?
  opponent   Opponent? @relation(fields: [opponentId], references: [id], onDelete: Cascade)
  clubId     Int?
  club       Club?     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  games      Game[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model AccountClub {
  id        Int               @id @default(autoincrement())
  accountId Int
  clubId    Int
  createdAt DateTime          @default(now())
  account   Account           @relation("AccountToClubs", fields: [accountId], references: [id], onDelete: Cascade)
  club      Club              @relation("ClubToAccounts", fields: [clubId], references: [id], onDelete: Cascade)
  roles     AccountClubRole[]

  @@unique([accountId, clubId])
}

model AccountClubRole {
  id            Int         @id @default(autoincrement())
  accountClubId Int
  role          Role
  accountClub   AccountClub @relation(fields: [accountClubId], references: [id], onDelete: Cascade)
}

model Team {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(50)
  type        TeamType?
  clubId      Int
  club        Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  echelonId   Int
  echelon     Echelon       @relation(fields: [echelonId], references: [id], onDelete: Cascade)
  fpbTeamId   Int?
  athletes    TeamAthlete[]
  staff       TeamStaff[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  games       Game[]
  macrocycles Macrocycle[]
  practices   Practice[]
}

model TeamAthlete {
  id        Int     @id @default(autoincrement())
  teamId    Int
  athleteId Int
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([teamId, athleteId])
}

model Staff {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(100)
  birthdate  DateTime?
  tptdNumber Int? // Carteira TPTD
  fpbLicense Int? // Licença FPB
  grade      CoachGrade?
  role       StaffRole
  active     Boolean     @default(true)
  clubId     Int
  club       Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teams      TeamStaff[]
  accountId  Int?
  account    Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([clubId, accountId])
  @@index([accountId])
}

model TeamStaff {
  id        Int     @id @default(autoincrement())
  teamId    Int
  staffId   Int
  isPrimary Boolean @default(false) // Treinador principal vs adjunto
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([teamId, staffId])
}

model Competition {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(50)
  description String? @db.VarChar(255)
  image       String? @db.Text
  echelonId   Int
  echelon     Echelon @relation(fields: [echelonId], references: [id], onDelete: Cascade)

  fpbCompetitionId Int?

  competitionSeries CompetitionSerie[]
  games             Game[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model CompetitionSerie {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(50)

  fpbSerieId Int?

  competitionId Int
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  games         Game[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model AthletePreferredNumber {
  id        Int     @id @default(autoincrement())
  athleteId Int
  color     String
  number    Int
  athlete   Athlete @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([athleteId, color])
}

model EquipmentColor {
  id        Int @id @default(autoincrement())
  clubId    Int
  seasonId  Int
  echelonId Int

  club    Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  season  Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  echelon Echelon @relation(fields: [echelonId], references: [id], onDelete: Cascade)

  color          String
  colorHex       String @default("#000000")
  numberColorHex String @default("#FFFFFF")

  equipments     Equipment[]
  gameEquipments GameEquipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clubId, seasonId, echelonId, color])
  @@index([clubId])
  @@index([clubId, seasonId])
  @@index([clubId, seasonId, echelonId])
}

model Equipment {
  id               Int @id @default(autoincrement())
  equipmentColorId Int

  equipmentColor EquipmentColor @relation(fields: [equipmentColorId], references: [id], onDelete: Cascade)

  number Int
  size   Size

  gameEquipments GameEquipment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([equipmentColorId])
}

model GameEquipment {
  id               Int     @id @default(autoincrement())
  gameId           Int
  athleteId        Int
  equipmentId      Int
  equipmentColorId Int
  manualOverride   Boolean @default(false)

  game           Game           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  athlete        Athlete        @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  equipment      Equipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  equipmentColor EquipmentColor @relation(fields: [equipmentColorId], references: [id], onDelete: Cascade)

  @@unique([gameId, athleteId, equipmentColorId])
  @@index([gameId])
  @@index([athleteId])
  @@index([equipmentColorId])
}

model Alert {
  id            Int           @id @default(autoincrement())
  clubId        Int
  type          AlertType
  category      AlertCategory
  title         String        @db.VarChar(200)
  message       String        @db.Text
  linkUrl       String?       @db.VarChar(500)
  referenceType String?       @db.VarChar(50)
  referenceId   Int?
  triggerDate   DateTime
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())

  club       Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  recipients AlertRecipient[]

  @@unique([clubId, category, referenceType, referenceId, triggerDate])
  @@index([clubId])
  @@index([triggerDate])
}

model AlertRecipient {
  id        Int                  @id @default(autoincrement())
  alertId   Int
  accountId Int
  status    AlertRecipientStatus @default(UNREAD)
  readAt    DateTime?
  deletedAt DateTime?
  createdAt DateTime             @default(now())

  alert   Alert   @relation(fields: [alertId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([alertId, accountId])
  @@index([accountId, status])
}

model Practice {
  id             Int      @id @default(autoincrement())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  clubId         Int
  club           Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  teamId         Int
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  date           DateTime
  endTime        DateTime
  subtitle       String?  @db.VarChar(255)
  topic          String   @db.VarChar(255)
  offensiveGoals String?  @db.VarChar(500)
  defensiveGoals String?  @db.VarChar(500)
  notes          String?  @db.Text
  completed      Boolean  @default(false)
  /// Optional JSON describing one or more independent group sets the
  /// coach uses to split the squad into teams during the session.
  /// Shape: `{ sets: Array<{ id, name, teams: Array<{ id, name, players: (athleteId|null)[] }> }> }`.
  /// Athlete IDs are validated against the practice's roster on save.
  groups         Json?

  attendances PracticeAthlete[]
  items       PracticeItem[]

  @@index([clubId, date])
  @@index([teamId, date])
}

model PracticeItem {
  id         Int              @id @default(autoincrement())
  practiceId Int
  practice   Practice         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  order      Int
  duration   Int              @default(0)
  type       PracticeItemType @default(FREETEXT)
  title      String?          @db.VarChar(255)
  text       String?          @db.Text
  drillId    Int?
  drill      Drill?           @relation(fields: [drillId], references: [id], onDelete: SetNull)
  /// Per-graphic overrides stored as a JSON array of
  /// `{ drillGraphicId, caption, printFirst, printOther }`. Captions and
  /// print flags live on the practice item so the same drill can be used
  /// in multiple practice plans with different annotations. The SVGs
  /// themselves are never duplicated here — the UI looks them up from
  /// the linked drill at render time.
  graphics   Json?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([practiceId, order])
}

model PracticeAthlete {
  id         Int      @id @default(autoincrement())
  practiceId Int
  athleteId  Int
  /// Whether the coach expected this athlete to be present at the session.
  attending  Boolean  @default(true)
  /// null = not yet filled in, true = attended, false = did not show up.
  attended   Boolean?
  /// How many minutes late the athlete showed up (only meaningful when
  /// `attended == true`).
  lateMinutes     Int?
  /// Reason for the absence when `attended == false`. Points at a
  /// club-scoped reason which may be one of the seeded defaults or a
  /// custom one.
  absenceReasonId Int?
  absenceReason   ClubAttendanceReason? @relation(fields: [absenceReasonId], references: [id], onDelete: SetNull)
  /// Free-form clarification entered next to the reason ("Other | Reason:").
  absenceNotes    String?               @db.Text
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)

  @@unique([practiceId, athleteId])
  @@index([practiceId])
  @@index([athleteId])
  @@index([absenceReasonId])
}

/// Club-scoped list of pre-canned reasons for absence. Seeded with a
/// default set (Injured / Sick / Unexcused / Other) the first time it is
/// read; clubs can add, rename and remove entries.
model ClubAttendanceReason {
  id     Int    @id @default(autoincrement())
  clubId Int
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  /// Localisation key for seeded defaults. `null` for custom reasons.
  key    String? @db.VarChar(40)
  name   String  @db.VarChar(120)
  order  Int     @default(0)
  athletes PracticeAthlete[]

  @@unique([clubId, key])
  @@index([clubId, order])
}

model ClubPracticeSettings {
  id                      Int               @id @default(autoincrement())
  clubId                  Int               @unique
  club                    Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  defaultAttendanceMale   AttendanceDefault @default(ALL)
  defaultAttendanceFemale AttendanceDefault @default(ALL)
  defaultAttendanceCoed   AttendanceDefault @default(ALL)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
}
