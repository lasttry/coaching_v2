# Database connection string (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/coaching

# Optional: shadow database used by `prisma migrate diff --from-migrations`
# and similar developer-only commands. Production (`prisma migrate deploy`)
# does NOT need this. Create the DB once locally with:
#   psql -U <admin> -c "CREATE DATABASE coaching_shadow;"
# SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/coaching_shadow

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=replace-me

# OpenAI API key (if used by the application)
OPENAI_API_KEY=replace-me

# Secret required by scheduled endpoints (e.g. /api/alerts/generate).
# The systemd timer in deploy/cron/ sends it as `Authorization: Bearer ${CRON_SECRET}`.
# Manual triggers can also use the `x-cron-secret` header.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me

# Key used to encrypt SMTP passwords stored in ClubEmailSettings.passEncrypted.
# MUST decode to exactly 32 bytes (AES-256-GCM). Accepts hex (64 chars) or base64.
# Generate with: openssl rand -base64 32
# WARNING: rotating this key invalidates all stored SMTP passwords.
EMAIL_ENCRYPTION_KEY=replace-me
