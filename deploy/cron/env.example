# Copy to /etc/coaching/cron.env on the server and fill the values.
# File permissions: chmod 600 /etc/coaching/cron.env (contains a secret).

# Public base URL of the coaching app (no trailing slash).
BASE_URL=https://your-domain.example

# Must match CRON_SECRET configured in the app's .env.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-me
